rules {
  inputs X, roi, scales, sizes;
  outputs Y;
  attributes axes;

  let raw_sc = shape_value(scales);
  let raw_sz = shape_value(sizes);
  let ax = attribute("axes", []);
  let sc = if raw_sc == [] then [] else overlay(raw_sc, ones(rank(X)), ax);
  let sz = if raw_sz == [] then [] else overlay(raw_sz, shape(X), ax);

  result Y.shape = resize_shape(shape(X), sc, sz);
  result Y.type = type(X);
}
