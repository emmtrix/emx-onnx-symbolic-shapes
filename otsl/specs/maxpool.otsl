rules {
  inputs X;
  outputs Y, Indices;
  attributes kernel_shape, strides, pads, dilations, ceil_mode, auto_pad, storage_order;

  result Y.shape = pool_shape(shape(X), kernel_shape, strides, pads, dilations, ceil_mode, auto_pad);
  result Indices.shape = pool_shape(shape(X), kernel_shape, strides, pads, dilations, ceil_mode, auto_pad);
  result Y.type = type(X);
  result Indices.type = int64;
}
