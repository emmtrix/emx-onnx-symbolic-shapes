# Gather – Gather entries from the data tensor along the given axis
# using the provided index tensor.
# The output shape replaces the axis dimension of data with the full
# shape of indices.
shape {
  inputs data, indices;
  outputs output;
  attributes axis;

  let ax = normalize_axis(axis, rank(data));

  result output = concat(concat(prefix(data, ax), shape(indices)), suffix(data, ax + 1));
}
