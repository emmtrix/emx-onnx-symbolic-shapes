rules {
  inputs X, K;
  outputs Values, Indices;
  attributes axis;

  let ax = normalize_axis(axis, rank(X));
  let k_val = shape_value(K);

  result Values.shape = topk_shape(shape(X), ax, k_val);
  result Indices.shape = topk_shape(shape(X), ax, k_val);
  result Values.type = type(X);
  result Indices.type = int64;
}
