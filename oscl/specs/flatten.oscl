# Flatten – Flatten a tensor into a 2D matrix.
# Dimensions before the axis are collapsed into the first output
# dimension; dimensions from the axis onward form the second.
# Default axis is 1.
shape {
  inputs input;
  outputs output;
  attributes axis;

  let ax = normalize_axis(axis, rank(input));

  result output = [prod(prefix(input, ax)), prod(suffix(input, ax))];
}
