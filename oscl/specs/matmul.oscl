# MatMul – Matrix multiplication with broadcasting on batch dimensions.
# The last two dimensions follow standard matrix multiply rules (MxK @ KxN -> MxN).
# Leading batch dimensions are broadcast using NumPy-style rules.
shape {
  inputs A, B;
  outputs Y;

  require dim(A,-1) == dim(B,-2);

  let batch = broadcast(prefix(A,-2), prefix(B,-2));

  result Y = concat(batch, [dim(A,-2), dim(B,-1)]);
}
